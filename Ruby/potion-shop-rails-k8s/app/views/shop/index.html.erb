<div class="zelda-container">
  <!-- Banner with Triforce -->
  <div class="banner-container">
    <%= image_tag("banner.svg", alt: "Benson's Potion Store", class: "banner") %>
  </div>

  <!-- Main Shop Area -->
  <div class="shop-frame">
    <div class="shop-header">
      <h1 class="shop-title">Benson's Potion Shop</h1>
      <p class="shop-subtitle">Premium Potions for Brave Adventurers</p>
    </div>

    <!-- Stats Display -->
    <div class="stats-container">
      <div class="stat-box">
        <div class="stat-label">Potions Sold</div>
        <div id="potions-sold" class="stat-value">0</div>
      </div>
      <div class="stat-box">
        <div class="stat-label">Gold Earned</div>
        <div id="gold-earned" class="stat-value">0</div>
      </div>
    </div>

    <!-- Potion Cards -->
    <div class="potions-grid">
      <div class="potion-card">
        <%= image_tag("red-potion.svg", alt: "Red Potion", class: "potion-image") %>
        <h3 class="potion-name">Red Potion</h3>
        <p class="potion-description">Restores health and vitality</p>
        <div class="potion-price">50 Gold</div>
        <button class="buy-button" onclick="buyPotion()">Buy Potion</button>
      </div>

      <div class="potion-card">
        <%= image_tag("red-potion.svg", alt: "Red Potion", class: "potion-image") %>
        <h3 class="potion-name">Red Potion</h3>
        <p class="potion-description">Restores health and vitality</p>
        <div class="potion-price">50 Gold</div>
        <button class="buy-button" onclick="buyPotion()">Buy Potion</button>
      </div>

      <div class="potion-card">
        <%= image_tag("red-potion.svg", alt: "Red Potion", class: "potion-image") %>
        <h3 class="potion-name">Red Potion</h3>
        <p class="potion-description">Restores health and vitality</p>
        <div class="potion-price">50 Gold</div>
        <button class="buy-button" onclick="buyPotion()">Buy Potion</button>
      </div>
    </div>

    <!-- Message Display -->
    <div id="message" class="message-box"></div>

    <!-- Reset Button -->
    <div class="reset-container">
      <button class="reset-button" onclick="resetStats()">Reset Stats</button>
    </div>
  </div>
</div>

<script>
  // Fetch and update stats on page load
  async function updateStats() {
    try {
      const response = await fetch('/api/stats');
      const data = await response.json();
      document.getElementById('potions-sold').textContent = data.potions_sold;
      document.getElementById('gold-earned').textContent = data.gold_earned;
    } catch (error) {
      console.error('Error fetching stats:', error);
    }
  }

  // Buy a potion
  async function buyPotion() {
    try {
      const response = await fetch('/api/buy', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        }
      });
      const data = await response.json();

      // Update stats
      document.getElementById('potions-sold').textContent = data.potions_sold;
      document.getElementById('gold-earned').textContent = data.gold_earned;

      // Show message
      const messageBox = document.getElementById('message');
      messageBox.textContent = data.message;
      messageBox.classList.add('show');

      // Hide message after 3 seconds
      setTimeout(() => {
        messageBox.classList.remove('show');
      }, 3000);
    } catch (error) {
      console.error('Error buying potion:', error);
    }
  }

  // Reset stats
  async function resetStats() {
    if (!confirm('Are you sure you want to reset all statistics?')) {
      return;
    }

    try {
      const response = await fetch('/api/reset', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        }
      });
      const data = await response.json();

      // Update stats
      document.getElementById('potions-sold').textContent = data.potions_sold;
      document.getElementById('gold-earned').textContent = data.gold_earned;

      // Show message
      const messageBox = document.getElementById('message');
      messageBox.textContent = data.message;
      messageBox.classList.add('show');

      // Hide message after 3 seconds
      setTimeout(() => {
        messageBox.classList.remove('show');
      }, 3000);
    } catch (error) {
      console.error('Error resetting stats:', error);
    }
  }

  // Load stats on page load
  document.addEventListener('DOMContentLoaded', updateStats);
</script>
