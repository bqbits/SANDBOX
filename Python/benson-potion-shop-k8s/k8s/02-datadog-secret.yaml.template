# Datadog API Key Secret Template
#
# IMPORTANT: Replace YOUR_DATADOG_API_KEY with your actual Datadog API key
# Then rename this file to 02-datadog-secret.yaml
#
# To create the secret from command line instead:
# kubectl create secret generic datadog-secret \
#   --from-literal=api-key=YOUR_DATADOG_API_KEY \
#   -n bensons-shop

apiVersion: v1
kind: Secret
metadata:
  name: datadog-secret
  namespace: bensons-shop
type: Opaque
stringData:
  api-key: YOUR_DATADOG_API_KEY
